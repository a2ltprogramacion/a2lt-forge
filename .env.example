# .env.example — La Forja — Template de Variables de Entorno
# Copiar a .env y completar con valores reales
# NUNCA committear .env con credenciales reales

FORJA_ENV=development
FORJA_LOG_LEVEL=INFO
FORJA_ROOT=./
FORJA_ALLOW_WRITES=true

RAG_PROVIDER=chromadb
RAG_INDEX_PATH=./rag/index
RAG_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
RAG_MIN_SCORE_THRESHOLD=0.7
RAG_TOP_K=5
RAG_AUTO_REINDEX=true

QUARANTINE_LAB_PATH=./quarantine_lab
EXTERNAL_AUDIT_TIMEOUT=86400
WORKFLOW_STATE_PATH=./quarantine_lab/workflow-state.json
PYTHON_MIN_VERSION=3.10

# ==============================================================================
# EXTERNAL INTEGRATIONS
# ==============================================================================

# GoHighLevel API
GHL_API_KEY=<tu-api-key-aquí>
GHL_LOCATION_ID=<tu-location-id-aquí>
GHL_AGENCY_API_KEY=<tu-agency-api-key-aquí>
GHL_WL_DOMAIN=<tu-white-label-domain-aquí>
GHL_SESSION_TOKEN=<tu-session-token-aquí>

# LM Studio - Local AI Model
LM_STUDIO_BASE_URL=http://127.0.0.1:1234/v1
LM_STUDIO_API_KEY=<tu-api-key-aquí>
LM_STUDIO_MODEL_ID=deepseek-coder-v2-lite-instruct

# Búsqueda web: "antigravity" (nativo) | "duckduckgo" (fallback)
WEB_SEARCH_PROVIDER=duckduckgo

SECRET_KEY=<cambia-esta-clave-en-producción>
DEBUG=true

AUDIT_LOG_ENABLED=true
AUDIT_LOG_PATH=./rag/sources/sessions/audit.log
PERSISTENT_WORKFLOW_STATE=true
