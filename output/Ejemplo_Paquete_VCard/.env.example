# .env.example — La Forja — Ejemplo de variables de entorno

# No llenar con valores reales. Este archivo es referencia.
# Crear .env local con valores reales de tu entorno.

## Framework
FORJA_ENV=development
FORJA_LOG_LEVEL=INFO

## Integración Con Plataformas Externas
# GoHighLevel (si aplica)
GHL_API_KEY=<your-api-key-here>
GHL_WORKSPACE_ID=<your-workspace-id-here>

## Base de datos (si aplica)
DATABASE_URL=postgres://user:password@localhost:5432/dbname
SQLITE_PATH=./local.db  # Solo desarrollo

## Credenciales de terceros (NUNCA en código)
# STRIPE_SECRET_KEY=sk_...
# SENDGRID_API_KEY=SG...

## Configuración de despliegue
DEBUG=False  # Never True en producción
SECRET_KEY=change-this-in-production
ALLOWED_HOSTS=localhost,127.0.0.1
